# Copy this file to .env and set real values. Never commit .env.

# Anthropic
ANTHROPIC_API_KEY=sk-ant-api03-REPLACE_WITH_YOUR_KEY

# Jira (required for --from-jira mode)
JIRA_EMAIL=your-email@example.com
JIRA_API_TOKEN=ATATT-REPLACE_WITH_YOUR_TOKEN
JIRA_BASE_URL=https://space307.atlassian.net

# Google Drive (required for --to-sheets mode)
# Get folder ID from the URL when you open the folder in Drive:
# https://drive.google.com/drive/folders/<THIS_PART>
GDRIVE_OUTPUT_FOLDER_ID=REPLACE_WITH_YOUR_FOLDER_ID